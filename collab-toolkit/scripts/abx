#!/usr/bin/env bash
# abx — agent-browser eXtended wrapper.
# Resolves profile arg from ~/.config/collab-toolkit/config.json,
# then `exec agent-browser` with --profile prepended.
#
# v0.1.2 schema:
#   {"mode": "shared",     "chrome_profile": "<name>",   ...}    → --profile <name>
#   {"mode": "dedicated",  "dedicated_profile": "<path>", ...}   → --profile <expanded path>
#
# v0.1.0/v0.1.1 dedicated mode used per-service paths under `profiles_root`
# + `ABX_SERVICE` env var. Migration: re-run /collab-setup --switch-mode (or
# /collab-setup --dedicated) to write the v0.1.2 unified-profile config.

set -euo pipefail

CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/collab-toolkit/config.json"

if [ ! -f "$CONFIG" ]; then
  echo "ERR: $CONFIG not found. Run /collab-setup first." >&2
  exit 1
fi

MODE=$(jq -r .mode "$CONFIG")

if [ "$MODE" = "dedicated" ]; then
  DEDICATED_PROFILE=$(jq -r .dedicated_profile "$CONFIG" 2>/dev/null || echo "")
  if [ -z "$DEDICATED_PROFILE" ] || [ "$DEDICATED_PROFILE" = "null" ]; then
    echo "ERR: dedicated mode config has no 'dedicated_profile' field." >&2
    echo "  Likely v0.1.0/v0.1.1 per-service config. Migrate by running:" >&2
    echo "  /collab-setup --switch-mode   # toggles to shared then back to dedicated unified" >&2
    echo "  /collab-setup --dedicated     # writes v0.1.2 unified config directly" >&2
    exit 1
  fi
  # Tilde expansion
  DEDICATED_PROFILE="${DEDICATED_PROFILE/#\~/$HOME}"
  exec agent-browser --profile "$DEDICATED_PROFILE" "$@"
else
  PROFILE_NAME=$(jq -r .chrome_profile "$CONFIG")
  exec agent-browser --profile "$PROFILE_NAME" "$@"
fi
