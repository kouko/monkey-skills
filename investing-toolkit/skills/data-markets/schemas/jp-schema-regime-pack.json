{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://monkey-skills/investing-toolkit/data-jp/regime-pack.json",
  "title": "data-jp regime-pack output",
  "description": "Output of `pack.py --pack regime-pack`. JP macro indicators — BOJ Call Rate O/N + Tankan inflation outlook (1/3/5y) + Tankan 業況判断 DI (4 categories: large/small × mfg/non-mfg, ADR-0004 PR-3), e-Stat preset bundle (cpi / core-cpi / ip / unemployment / jgb10y / coincident-index / leading-index / machine-orders), ECB JP real 10Y yield. Always Tier A (BOJ + 統計DB + ECB are all primary-source / no key required). Note: `groups.real_rates.real_10y_monthly_ecb` may be null or carry an empty `observations` array per `analysis-macro-regime/references/japan-real-rate-roadmap.md` — Layer 2 callers must handle missing real-rate observations gracefully.",
  "type": "object",
  "required": [
    "pack",
    "fetched_at",
    "groups",
    "_provenance"
  ],
  "properties": {
    "pack": {
      "type": "string",
      "const": "regime-pack"
    },
    "fetched_at": {
      "type": "string",
      "format": "date-time"
    },
    "groups": {
      "type": "object",
      "required": [
        "rates",
        "inflation",
        "real_rates"
      ],
      "properties": {
        "rates": {
          "type": "object",
          "required": [
            "call_rate_on"
          ],
          "properties": {
            "call_rate_on": {
              "description": "BOJ Time-Series API — Call Rate Overnight (FM01/STRDCLUCON). Object includes `series`, `name`, `unit`, `frequency`, `observations`, `latest`, `count`. May be error envelope.",
              "oneOf": [
                {
                  "type": "object",
                  "properties": {
                    "series": {
                      "type": "string"
                    },
                    "name": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "unit": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "frequency": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "observations": {
                      "type": [
                        "array",
                        "object",
                        "null"
                      ]
                    },
                    "latest": {
                      "type": [
                        "number",
                        "object",
                        "null"
                      ]
                    },
                    "count": {
                      "type": [
                        "integer",
                        "null"
                      ]
                    }
                  }
                },
                {
                  "$ref": "https://monkey-skills/investing-toolkit/data-jp/error-envelope.json"
                }
              ]
            }
          }
        },
        "inflation": {
          "type": "object",
          "required": [
            "estat"
          ],
          "properties": {
            "estat": {
              "description": "e-Stat / 統計ダッシュボード preset bundle (cpi,core-cpi,ip,unemployment,jgb10y). Typical shape: `{indicators: {<key>: {...}}}`.",
              "oneOf": [
                {
                  "type": "object",
                  "properties": {
                    "indicators": {
                      "type": "object"
                    }
                  }
                },
                {
                  "$ref": "https://monkey-skills/investing-toolkit/data-jp/error-envelope.json"
                }
              ]
            }
          }
        },
        "real_rates": {
          "type": "object",
          "required": [
            "real_10y_monthly_ecb",
            "tankan_inflation_outlook"
          ],
          "description": "Real-rate group. `real_10y_monthly_ecb` MAY be null or carry an empty `observations` array — Layer 2 must check before reading. See analysis-macro-regime/references/japan-real-rate-roadmap.md.",
          "properties": {
            "real_10y_monthly_ecb": {
              "description": "ECB JP real 10Y yield ex-post (M.JP.JPY.4F.BB.R_JP10YT_RR.YLDA). `observations` may be empty if ECB data dropped.",
              "oneOf": [
                {
                  "type": "object",
                  "properties": {
                    "series": {
                      "type": "string"
                    },
                    "dataset": {
                      "type": [
                        "string",
                        "null"
                      ]
                    },
                    "observations": {
                      "type": [
                        "array",
                        "object",
                        "null"
                      ]
                    },
                    "latest": {
                      "type": [
                        "number",
                        "object",
                        "null"
                      ]
                    },
                    "count": {
                      "type": [
                        "integer",
                        "null"
                      ]
                    }
                  }
                },
                {
                  "type": "null"
                },
                {
                  "$ref": "https://monkey-skills/investing-toolkit/data-jp/error-envelope.json"
                }
              ]
            },
            "tankan_inflation_outlook": {
              "description": "BOJ Tankan 企業物価見通し 1Y/3Y/5Y. Object with per-horizon series.",
              "oneOf": [
                {
                  "type": "object"
                },
                {
                  "$ref": "https://monkey-skills/investing-toolkit/data-jp/error-envelope.json"
                }
              ]
            }
          }
        },
        "cycle": {
          "type": "object",
          "description": "PR-3 (ADR-0004): cycle-group placeholder — ESRI 景気動向指数 CI 一致/先行 + 機械受注 are fetched via the e-Stat preset bundle and surface as top-level series keys via the T2 flatten helper. This sub-object holds an alias note pointing at groups.inflation.estat for canonical observation paths.",
          "additionalProperties": true
        },
        "business_sentiment": {
          "type": "object",
          "description": "PR-3 (ADR-0004): Tankan 業況判断 DI — Large/Small × Manufacturing/Non-manufacturing (4 categories). Used by classify_jp.py. May be an error envelope on fetch failure (graceful degradation).",
          "properties": {
            "tankan_business_di": {
              "oneOf": [
                {
                  "type": "object"
                },
                {
                  "$ref": "https://monkey-skills/investing-toolkit/data-jp/error-envelope.json"
                }
              ]
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "_provenance": {
      "type": "object",
      "required": [
        "tier",
        "tier_label",
        "sources"
      ],
      "properties": {
        "tier": {
          "type": "string",
          "const": "tier_a"
        },
        "tier_label": {
          "type": "string",
          "const": "Tier A (BOJ + 統計DB + ECB primary-source)"
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      },
      "additionalProperties": true
    },
    "series": {
      "type": "object",
      "description": "T2 canonical flat alias per ADR-0002. Indicator-keyed dict of [floats] (chronological values). analysis-macro-regime / regime_compose.resolve_series reads this.",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    }
  },
  "additionalProperties": true
}
