{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "investing-toolkit/skills/analysis-comps/references/schema-compute-output.json",
  "title": "analysis-comps output (direct + compute modes)",
  "description": "Output JSON shape of comps_compute.py. See spec §8/§10. Validates both --mode direct and --mode compute (compute adds sector / schema_id / multiples_compute / divergence / indicators / compute_provenance fields per spec §8 v2.2.0-c).",
  "type": "object",
  "required": ["anchor", "peers", "statistics", "anchor_delta", "ranking", "_provenance"],
  "additionalProperties": false,
  "properties": {
    "anchor": {
      "type": "object",
      "required": ["ticker", "multiples_direct"],
      "additionalProperties": false,
      "properties": {
        "ticker": {"type": "string"},
        "sector": {"type": ["string", "null"]},
        "industry": {"type": ["string", "null"]},
        "schema_id": {"$ref": "#/$defs/schemaId"},
        "schema_routing_source": {"$ref": "#/$defs/schemaRoutingSource"},
        "multiples_direct": {"$ref": "#/$defs/multiplesBlock"},
        "multiples_compute": {"$ref": "#/$defs/multiplesBlock"},
        "divergence": {"$ref": "#/$defs/divergenceBlock"},
        "indicators": {"$ref": "#/$defs/indicatorsBlock"},
        "compute_provenance": {"$ref": "#/$defs/computeProvenanceBlock"},
        "etf_benchmark": {"$ref": "#/$defs/etfBenchmarkBlock"}
      }
    },
    "peers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ticker", "multiples", "rationale"],
        "additionalProperties": false,
        "properties": {
          "ticker": {"type": "string"},
          "multiples": {"$ref": "#/$defs/multiplesBlock"},
          "rationale": {"type": ["string", "null"]},
          "schema_id": {
            "anyOf": [
              {"$ref": "#/$defs/schemaId"},
              {"type": "null"}
            ]
          }
        }
      }
    },
    "statistics": {
      "type": "object",
      "propertyNames": {"$ref": "#/$defs/multipleId"},
      "additionalProperties": {
        "type": "object",
        "required": ["median", "mean", "q1", "q3", "min", "max", "n"],
        "properties": {
          "median": {"type": ["number", "null"]},
          "mean": {"type": ["number", "null"]},
          "q1": {"type": ["number", "null"]},
          "q3": {"type": ["number", "null"]},
          "min": {"type": ["number", "null"]},
          "max": {"type": ["number", "null"]},
          "n": {"type": "integer", "minimum": 0}
        }
      }
    },
    "anchor_delta": {
      "type": "object",
      "additionalProperties": {
        "type": ["object", "null"]
      }
    },
    "ranking": {
      "type": "array",
      "items": {"type": "object"}
    },
    "_provenance": {
      "type": "object",
      "required": ["skill", "anchor_data_source", "peer_data_sources", "computed_at", "io", "mode", "requested_mode", "warnings"],
      "additionalProperties": false,
      "properties": {
        "skill": {"const": "analysis-comps"},
        "anchor_data_source": {"type": "string"},
        "anchor_base_source": {"type": "string"},
        "peer_data_sources": {"type": "array", "items": {"type": "string"}},
        "computed_at": {"type": "string"},
        "io": {"const": "none"},
        "mode": {"enum": ["direct", "compute"]},
        "requested_mode": {"type": "string"},
        "schema_id": {"$ref": "#/$defs/schemaId"},
        "schema_version": {"type": ["string", "number", "null"]},
        "schema_routing_source": {"$ref": "#/$defs/schemaRoutingSource"},
        "warnings": {"type": "array", "items": {"type": "string"}}
      }
    }
  },
  "allOf": [
    {
      "comment": "compute-mode requirement: anchor must carry sector-routing fields and compute artefacts",
      "if": {
        "properties": {
          "_provenance": {"properties": {"mode": {"const": "compute"}}}
        }
      },
      "then": {
        "properties": {
          "anchor": {
            "required": [
              "sector", "industry", "schema_id", "schema_routing_source",
              "multiples_direct", "multiples_compute", "divergence",
              "indicators", "compute_provenance"
            ]
          },
          "_provenance": {
            "required": [
              "skill", "anchor_data_source", "anchor_base_source",
              "peer_data_sources", "computed_at", "io", "mode",
              "requested_mode", "schema_id", "schema_version",
              "schema_routing_source", "warnings"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "schemaId": {
      "type": "string",
      "enum": [
        "default", "bank", "insurance", "asset-manager", "reit",
        "tech-saas", "tech-semis", "energy", "utilities"
      ]
    },
    "schemaRoutingSource": {
      "type": "string",
      "enum": [
        "override", "industry_match", "sector_default",
        "unknown_sector", "cli_override"
      ]
    },
    "multipleId": {
      "type": "string",
      "enum": [
        "trailingPE", "forwardPE", "evEbitda", "priceToSales",
        "priceToBook", "priceToTangibleBook", "priceToFFO",
        "evEbitdare", "priceToCFO", "evRevenue"
      ]
    },
    "multiplesBlock": {
      "comment": "Subset of canonical multiple ids permitted by the active schema; values may be null when the source pack lacks the field.",
      "type": "object",
      "minProperties": 0,
      "additionalProperties": false,
      "patternProperties": {
        "^(trailingPE|forwardPE|evEbitda|priceToSales|priceToBook|priceToTangibleBook|priceToFFO|evEbitdare|priceToCFO|evRevenue)$": {
          "type": ["number", "null"]
        }
      }
    },
    "divergenceBlock": {
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^(trailingPE|forwardPE|evEbitda|priceToSales|priceToBook|priceToTangibleBook|priceToFFO|evEbitdare|priceToCFO|evRevenue)$": {
          "type": "object",
          "required": ["abs_diff", "pct_diff", "alert"],
          "properties": {
            "abs_diff": {"type": ["number", "null"]},
            "pct_diff": {"type": ["number", "null"]},
            "alert": {"enum": ["low", "medium", "high", "n/a"]},
            "note": {"type": "string"}
          }
        }
      }
    },
    "indicatorsBlock": {
      "comment": "Schema-defined indicator values; empty object when the schema declares no indicators (e.g. REIT). Keys are indicator_ids defined per schema; values are {value, unit}.",
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["value", "unit"],
        "properties": {
          "value": {"type": ["number", "null"]},
          "unit": {"type": "string"}
        }
      }
    },
    "computeProvenanceBlock": {
      "comment": "Keyed by multiple_id (canonical multiple set) AND by indicator_id (schema-defined). Both share entry shape with `computed:bool` flag — for indicators, formula execution success.",
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["computed"],
        "properties": {
          "numerator_source": {"type": "string"},
          "denominator_source": {"type": "string"},
          "accession_basis": {"type": "array", "items": {"type": "string"}},
          "fiscal_year_end": {"type": ["string", "null"]},
          "computed": {"type": "boolean"},
          "formula_id": {"type": "string"},
          "note": {"type": "string"}
        }
      }
    },
    "etfBenchmarkBlock": {
      "comment": "v2.2.0-c-bench: SPDR sector ETF aggregate benchmark layer. Emitted only when --sector-benchmark flag passed. Either {status, reason} (non-US / unmapped / aggregate-missing) OR {etf, schema_id, as_of, _meta, multiples, indicators, warnings} (US ticker with healthy aggregate).",
      "type": "object",
      "oneOf": [
        {
          "required": ["status", "reason"],
          "additionalProperties": false,
          "properties": {
            "status": {"const": "skipped"},
            "reason": {"type": "string"}
          }
        },
        {
          "required": ["etf", "schema_id", "as_of", "_meta", "multiples", "indicators", "warnings"],
          "additionalProperties": false,
          "properties": {
            "etf":       {"type": "string"},
            "schema_id": {"$ref": "#/$defs/schemaId"},
            "as_of":     {"type": "string"},
            "_meta":     {"type": "object"},
            "multiples": {
              "type": "object",
              "additionalProperties": {"$ref": "#/$defs/etfBenchEntry"}
            },
            "indicators": {
              "type": "object",
              "additionalProperties": {"$ref": "#/$defs/etfBenchEntry"}
            },
            "warnings":  {"type": "array", "items": {"type": "string"}}
          }
        }
      ]
    },
    "etfBenchEntry": {
      "type": "object",
      "required": ["individual", "etf_aggregate", "delta_pct", "band"],
      "additionalProperties": true,
      "properties": {
        "individual":    {"type": ["number", "null"]},
        "etf_aggregate": {"type": ["number", "null"]},
        "delta_pct":     {"type": ["number", "null"]},
        "band":          {"enum": ["in_line", "notable", "extreme", "n/a"]},
        "note":          {"type": "string"}
      }
    }
  }
}
