#!/usr/bin/env bash
# SessionStart hook for loom-code.
# Reads skills/using-loom-code/SKILL.md and injects it as additionalContext
# so every Claude Code / Codex CLI session starts with the router loaded.
#
# CANONICAL key (both hosts consume): hookSpecificOutput.additionalContext
# Per the official Codex hooks contract (developers.openai.com/codex/hooks):
# "That additionalContext text is added as extra developer context." Claude
# Code reads the SAME nested camelCase key, so this one shape is what both
# hosts actually consume.
#
# DEFENSIVE keys (belt-and-suspenders, emitted for cross-version/host
# portability — NOT because Codex requires snake_case):
#   additional_context   (top-level snake_case)
#   additionalContext    (bare top-level camelCase)
# These are harmless extras a host ignores if it doesn't read them; we emit
# all three so the router survives host/version shape drift. This is a
# deliberate design — tests/integration/test-superpowers-mode-off.sh asserts
# all 3 keys are present (Check 4).
#
# Escape hatch (Phase 1.5):
#   export LOOM_CODE_MODE=off   # skip injection (no-op JSON returned)
#
# Reference: loom-code/TECH-SPEC.md §2.3
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
SKILL_PATH="${PLUGIN_ROOT}/skills/using-loom-code/SKILL.md"

# Escape hatch — Superpowers coexistence.
# Emit canonical nested key + both defensive top-level keys (all empty).
if [ "${LOOM_CODE_MODE:-on}" = "off" ]; then
  printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":""},"additional_context":"","additionalContext":""}\n'
  exit 0
fi

# Skill file missing → fail open with empty context (do not crash the session).
# Same 3-key shape as the escape hatch.
if [ ! -f "${SKILL_PATH}" ]; then
  printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":""},"additional_context":"","additionalContext":""}\n'
  exit 0
fi

content="$(cat "${SKILL_PATH}")"

# JSON-escape via bash parameter substitution (mirror Superpowers).
escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}
escaped="$(escape_for_json "${content}")"

# Wrap in EXTREMELY-IMPORTANT block so the agent treats the router as load-bearing.
banner_open='<EXTREMELY_IMPORTANT>\nYou have loom-code. Routing through this skill is mandatory when applicable.\n\n'
banner_close='\n</EXTREMELY_IMPORTANT>'
context="${banner_open}${escaped}${banner_close}"

# Emit canonical nested key + both defensive top-level keys (same content).
printf '{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"%s"},"additional_context":"%s","additionalContext":"%s"}\n' \
  "${context}" "${context}" "${context}"
