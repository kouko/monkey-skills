# macOS Finder noise
.DS_Store
**/.DS_Store
._*

# Windows
Thumbs.db

# Claude Code local settings
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/scheduled_tasks.json

# Local-only scratch with private/cross-project context — NEVER commit.
# Handoffs (cold-reader continuation) and embedded worktrees legitimately
# reference private repos / customer context; they are personal, not shippable.
.claude/handoffs/
.claude/worktrees/

# Keep .gitkeep files
!**/.gitkeep

# Git worktrees
.worktrees/

# MCP server caches
.playwright-mcp/
.chrome-devtools-mcp/

# Python bytecode caches (generated by pytest / uv run; never tracked)
**/__pycache__/
*.py[cod]
*$py.class

# Skill eval-loop ephemeral output (run_loop / skill-judge history JSONL)
**/.run_loop-results/
**/.skill-judge-history.jsonl

# OAuth / credentials / secrets — never commit
# (Plugins must not ship client_secret / api_key / access_token. Public
# client_id may live in user-level ~/.claude.json mcpServers, never in
# plugin.json which is shipped to all users.)
*.env
.env.*
!.env.example
**/credentials.json
**/credentials.*.json
!**/credentials.example.json
*-secret.json
*-secrets.json
oauth-*.json
!oauth-*.example.json
*.pem
*.key
!*.pub.key
briefing-toolkit/skills/daily-brief-workspace/
