{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/git-guard-shim.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/validate-skill-folder-structure.sh"
          },
          {
            "type": "command",
            "command": ".codex/hooks/remind-memory-mirror.sh"
          }
        ]
      }
    ]
  }
}
