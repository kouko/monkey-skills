{
  "permissions": {
    "deny": [
      "Read(~/.config/gws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.cache/gws-toolkit/bin/.version)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/client_secret*.json)",
      "Read(**/credentials.enc)",
      "Read(**/.encryption_key)",
      "Bash(cat ~/.config/gws/*)",
      "Bash(cat ~/.config/gws/**)",
      "Bash(cp ~/.config/gws/* *)",
      "Bash(git add ~/.config/gws/*)",
      "Write(~/.config/gws/**)"
    ]
  }
}
